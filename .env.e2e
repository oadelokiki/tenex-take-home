# E2E stack only — loaded when TENEX_USE_E2E_ENV=1 (see README). Do not use in production.
E2E_MODE=1
E2E_SECRET=playwright-e2e-local-secret

NODE_ENV=development
PORT=3000
HOST=127.0.0.1

GOOGLE_CLIENT_ID=e2e-placeholder.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=e2e-placeholder-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:4173/auth/google/callback
PUBLIC_WEB_ORIGIN=http://127.0.0.1:4173

SESSION_SECRET=01234567890123456789012345678901

OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M

CALENDAR_MAX_RANGE_DAYS=32
