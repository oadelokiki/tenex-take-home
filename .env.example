# Copy to .env for local API (and optionally set TENEX_ENV_FILE=./.env for Docker Compose).
# Production: place secrets in /opt/tenex-take-home/.env on the droplet (chmod 600).

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Local dev: use the SAME origin:port as the Vite app so Set-Cookie is stored for the SPA (Vite proxies /auth to the API).
# Vite’s dev server port is taken from PUBLIC_WEB_ORIGIN (strictPort) so it cannot drift to another port silently.
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
# Docker Compose + nginx on port 80 — use instead when testing Compose locally:
# GOOGLE_REDIRECT_URI=http://localhost/auth/google/callback

# Where to send the browser after Google OAuth (must match Vite URL you open). Production: e.g. https://your.domain
PUBLIC_WEB_ORIGIN=http://localhost:5173

# At least 32 characters
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

OLLAMA_URL=http://127.0.0.1:11434
# Pin exact Mistrallite / Mistral-family tag for your environment, e.g.:
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M

CALENDAR_MAX_RANGE_DAYS=32
